<UserControl x:Class="CStoValuation.App.Views.MoversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CStoValuation.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MoversViewModel}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="BIGGEST MOVERS (7D vs 30D)" FontSize="11"
                           VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                <ComboBox Grid.Column="1" Width="120"
                          ItemsSource="{Binding Metrics}"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedMetric}"
                          ToolTip="Rank movers by % change, per-unit value, or total value" />
            </Grid>

            <!-- Empty state -->
            <TextBlock Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Center" TextAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="No movers to show yet — connect an inventory with items that have recent sales.">
    <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasMovers}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Movers}"
                          Visibility="{Binding HasMovers, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="84" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="{Binding LatestPriceText}" Margin="8,0"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" HorizontalAlignment="Right"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPositive}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource PositiveBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
